# Claude / Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Meta / Instagram
META_ACCESS_TOKEN=your_long_lived_meta_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# Imgur — נדרש להעלאת תמונות אישיות מה-media/ folder
# הרשמה חינמית: https://api.imgur.com/oauth2/addclient
IMGUR_CLIENT_ID=your_imgur_client_id_here

# Pexels (אופציונלי — תמונות ברירת מחדל אם אין תמונות אישיות)
# הרשמה חינמית: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here
